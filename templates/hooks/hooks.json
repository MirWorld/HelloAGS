{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { $root=$env:HELLOAGENTS_SKILL_ROOT; if ([string]::IsNullOrWhiteSpace($root)) { $codexHome=$env:CODEX_HOME; if ([string]::IsNullOrWhiteSpace($codexHome)) { $codexHome=Join-Path $HOME '.codex' }; $root=Join-Path $codexHome 'skills/helloagents' }; & (Join-Path $root 'scripts/hooks/helloagents-sessionstart.ps1') }\"",
            "timeoutSec": 10,
            "statusMessage": "helloagents: session start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { $root=$env:HELLOAGENTS_SKILL_ROOT; if ([string]::IsNullOrWhiteSpace($root)) { $codexHome=$env:CODEX_HOME; if ([string]::IsNullOrWhiteSpace($codexHome)) { $codexHome=Join-Path $HOME '.codex' }; $root=Join-Path $codexHome 'skills/helloagents' }; & (Join-Path $root 'scripts/hooks/helloagents-userpromptsubmit.ps1') }\"",
            "timeoutSec": 10,
            "statusMessage": "helloagents: prompt guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { $root=$env:HELLOAGENTS_SKILL_ROOT; if ([string]::IsNullOrWhiteSpace($root)) { $codexHome=$env:CODEX_HOME; if ([string]::IsNullOrWhiteSpace($codexHome)) { $codexHome=Join-Path $HOME '.codex' }; $root=Join-Path $codexHome 'skills/helloagents' }; & (Join-Path $root 'scripts/hooks/helloagents-stop.ps1') }\"",
            "timeoutSec": 10,
            "statusMessage": "helloagents: stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { $root=$env:HELLOAGENTS_SKILL_ROOT; if ([string]::IsNullOrWhiteSpace($root)) { $codexHome=$env:CODEX_HOME; if ([string]::IsNullOrWhiteSpace($codexHome)) { $codexHome=Join-Path $HOME '.codex' }; $root=Join-Path $codexHome 'skills/helloagents' }; & (Join-Path $root 'scripts/hooks/helloagents-compact.ps1') }\"",
            "timeoutSec": 10,
            "statusMessage": "helloagents: pre compact checkpoint"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { $root=$env:HELLOAGENTS_SKILL_ROOT; if ([string]::IsNullOrWhiteSpace($root)) { $codexHome=$env:CODEX_HOME; if ([string]::IsNullOrWhiteSpace($codexHome)) { $codexHome=Join-Path $HOME '.codex' }; $root=Join-Path $codexHome 'skills/helloagents' }; & (Join-Path $root 'scripts/hooks/helloagents-compact.ps1') }\"",
            "timeoutSec": 10,
            "statusMessage": "helloagents: pre compact checkpoint"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { $root=$env:HELLOAGENTS_SKILL_ROOT; if ([string]::IsNullOrWhiteSpace($root)) { $codexHome=$env:CODEX_HOME; if ([string]::IsNullOrWhiteSpace($codexHome)) { $codexHome=Join-Path $HOME '.codex' }; $root=Join-Path $codexHome 'skills/helloagents' }; & (Join-Path $root 'scripts/hooks/helloagents-compact.ps1') }\"",
            "timeoutSec": 10,
            "statusMessage": "helloagents: post compact checkpoint"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { $root=$env:HELLOAGENTS_SKILL_ROOT; if ([string]::IsNullOrWhiteSpace($root)) { $codexHome=$env:CODEX_HOME; if ([string]::IsNullOrWhiteSpace($codexHome)) { $codexHome=Join-Path $HOME '.codex' }; $root=Join-Path $codexHome 'skills/helloagents' }; & (Join-Path $root 'scripts/hooks/helloagents-compact.ps1') }\"",
            "timeoutSec": 10,
            "statusMessage": "helloagents: post compact checkpoint"
          }
        ]
      }
    ]
  }
}
